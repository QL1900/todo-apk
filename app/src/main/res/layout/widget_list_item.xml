<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:background="#FFFFFF"
    android:weightSum="1">
    <TextView
        android:id="@+id/widgetItemTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.5"
        android:textSize="13sp"
        android:textColor="#1D2129"
        android:singleLine="true"
        android:ellipsize="end"/>
    <TextView
        android:id="@+id/widgetItemSystem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:textSize="10sp"
        android:textColor="#4E6EF2"
        android:layout_marginStart="6dp"/>
    <TextView
        android:id="@+id/widgetItemPriority"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        android:textSize="10sp"
        android:textColor="#F53F3F"
        android:layout_marginStart="4dp"
        android:visibility="gone"/>
    <TextView
        android:id="@+id/widgetItemDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#86909C"
        android:layout_marginStart="8dp"
        android:visibility="gone"/>
</LinearLayout>
